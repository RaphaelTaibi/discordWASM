{
  "name": "desktop",
  "private": true,
  "version": "0.1.11",
  "license": "BUSL-1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "wasm:build": "cd ../../packages/core-wasm && wasm-pack build --target web --out-dir ../../apps/desktop/src/pkg",
    "build": "tsc && vite build",
    "build:worklet": "vite build --config vite.worklet.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "csp:inject": "node scripts/inject-csp.mjs",
    "postinstall": "node scripts/inject-csp.mjs",
    "server:dev": "cd ../.. && $env:DEV_MODE=1; cargo run --package signaling-server",
    "server:prod": "cd ../.. && cargo run --package signaling-server --release",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tauri-apps/plugin-websocket": "^2.4.2",
    "jdenticon": "^3.3.0",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwind": "^4.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
