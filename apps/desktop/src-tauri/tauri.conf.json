  "productName": "DiscordWASM",
  "version": "0.1.10",
  "identifier": "com.discord.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DiscordWASM",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "RWRSZ0ZPKYcR18IPF5e3hsoPeYuQ44r4MqkEtY80zzi3G41dZV/QYyYH",
      "endpoints": [
        "https://github.com/RaphaelTaibi/discordWASM/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Raphael Taibi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
