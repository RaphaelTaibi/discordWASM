# Rust
/target/
**/*.rs.bk

# Node / JS
node_modules/
dist/
dist-ssr/

# WASM (generated by wasm-pack)
pkg/
!**/__mocks__/pkg/

# Tauri
src-tauri/target/
apps/desktop/src-tauri/gen/

# Generated worklet outputs (built via pnpm build:worklet)
apps/desktop/public/worker/*.js

# Environment files
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# AI / Agent docs
AGENTS.md

# Certificates
*.cert
*.key
*.pem

# Protocol Buffers (internal schema — security sensitive)
packages/signaling-server/proto/*.proto

# Runtime store files (generated by signaling-server)
*.bin

# OS
.DS_Store
Thumbs.db

# Temp / debug scratch files
_*.txt

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Build artifacts
*.pdb
*.dll
*.exe
*.exp
*.lib
*.rlib
*.d
*.local

# Dashboard notes (not source code)
apps/desktop/dashboard-settings.txt
